local library = loadstring(game:HttpGet("https://raw.githubusercontent.com/liebertsx/Tora-Library/main/src/librarynew", true))()

-- Window (no folder, features directly on window)
local window = library:CreateWindow("Xerhub")

-- Auto Click (ZERO DELAY - fastest possible loop)
window:AddToggle({
    text = "Auto Click",
    flag = "autoclick",
    state = false,
    callback = function(enabled)
        if enabled then
            getgenv().AutoClickLoop = task.spawn(function()
                while library.flags["autoclick"] do
                    pcall(function()
                        game:GetService("ReplicatedStorage").Remotes.Server.Click:FireServer()
                    end)
                    task.wait() -- 1 frame delay, basically instant
                end
            end)
        else
            getgenv().AutoClickLoop = nil
        end
    end
})


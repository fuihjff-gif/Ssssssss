    end
end)

-- ===== TP HELPER =====
local function TPTo(pos)
    local hrp = GetHRP()
    if not hrp then return end
    hrp.CFrame = CFrame.new(pos.X, pos.Y + 5, pos.Z)
    task.wait(0.1)
    hrp.AssemblyLinearVelocity = Vector3.new(0, 0, 0)
end

-- ===== MAIN LOOP (FASTER SCOOP + AUTO POUR WHEN FULL) =====
task.spawn(function()
    while true do
        RefreshCache()
        
        -- AUTO SCOOP: Faster (0.05s delay)
        if AutoScoop then
            local water = GetNearestWater()
            if water then
                local hrp = GetHRP()
                if hrp then
                    hrp.CFrame = CFrame.new(hrp.Position, Vector3.new(water.Position.X, hrp.Position.Y, water.Position.Z))
                end
                pcall(function()
                    VerdantRemotes:Fire("Bucket.Used")
                end)
            end
            task.wait(0.05) -- Fast scoop
        end
        
        -- AUTO POUR: Only when bucket is FULL (100%)
        if AutoPour then
            local fill = LocalPlayer:GetAttribute("BucketFill") or 0
            if fill >= 0.99 then -- Full bucket
                for _, drain in pairs(CachedDrains) do
                    TPTo(drain.Position)
                    task.wait(0.3)
                    pcall(function()
                        VerdantRemotes:Fire("Bucket.Poured", drain.Prompt)
                    end)
                    task.wait(0.3)
                end
            end
        end
        
        if AutoTake then
            for _, drain in pairs(CachedDrains) do
                TPTo(drain.Position)
                task.wait(0.3)
                pcall(function()
                    VerdantRemotes:Fire("Tokens.Take", drain.Prompt)
                end)
                task.wait(0.3)
            end
        end
        
        if AutoChest then
            for _, chestData in pairs(CachedChests) do
                local part = chestData.Part
                if part and part.Parent then
                    TPTo(part.Position)
                    task.wait(0.3)
                    pcall(function()
                        VerdantRemotes:Fire("Chest.Open", part)
                    end)
                    task.wait(0.3)
                end
            end
        end
        
        if ESPEnabled then
            UpdateESP()
        end
        
        if not AutoScoop then
            task.wait(0.5)
        end
    end
end)


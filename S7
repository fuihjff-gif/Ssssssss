local library = loadstring(game:HttpGet("https://raw.githubusercontent.com/liebertsx/Tora-Library/main/src/librarynew",true))()

local window = library:CreateWindow("Xerhub")

local Players = game:GetService("Players")
local LocalPlayer = Players.LocalPlayer
local remotes = game:GetService("ReplicatedStorage"):WaitForChild("NukeRemotes")

local function TpTo(pos)
    if not pos then return end
    local char = LocalPlayer.Character
    if not char then return end
    local hrp = char:FindFirstChild("HumanoidRootPart")
    if not hrp then return end
    pcall(function()
        hrp.CFrame = CFrame.new(pos) + Vector3.new(0, 5, 0)
    end)
end

local function GetNukePos(nuke)
    if not nuke or not nuke.Parent then return nil end
    local success, pos = pcall(function()
        if nuke:IsA("Model") then
            if nuke.PrimaryPart then
                return nuke.PrimaryPart.Position
            end
            return nuke:GetPivot().Position
        elseif nuke:IsA("BasePart") then
            return nuke.Position
        end
    end)
    if success then return pos end
    return nil
end

window:AddToggle({
    text = "Auto Nuke Farm",
    flag = "nuke_farm",
    callback = function(enabled)
        if enabled then
            task.spawn(function()
                while library.flags["nuke_farm"] do
                    local basesFolder = workspace:FindFirstChild("Bases")
                    
                    if basesFolder then
                        local myBase = nil
                        for _, base in ipairs(basesFolder:GetChildren()) do
                            local floor = base:FindFirstChild("Floor")
                            if floor then
                                local billboard = floor:FindFirstChild("BillboardGui")
                                if billboard then
                                    local textLabel = billboard:FindFirstChild("TextLabel")
                                    if textLabel then
                                        local txt = textLabel.Text
                                        if txt == LocalPlayer.Name or txt == LocalPlayer.DisplayName then
                                            myBase = base
                                            break
                                        end
                                    end
                                end
                            end
                        end

                        if myBase then
                            local nukesFolder = myBase:FindFirstChild("Nukes")
                            if nukesFolder then
                                local allNukes = {}
                                for _, nuke in ipairs(nukesFolder:GetChildren()) do
                                    local overhead = nuke:FindFirstChild("OverheadNuke")
                                    if overhead then
                                        local label = overhead:FindFirstChild("TextLabel")
                                        if label then
                                            local rawText = label.Text
                                            local pos = GetNukePos(nuke)
                                            if pos then
                                                table.insert(allNukes, {Text = rawText, Pos = pos, Obj = nuke})
                                            end
                                        end
                                    end
                                end

                                if #allNukes > 0 then
                                    local byText = {}
                                    for _, n in ipairs(allNukes) do
                                        if not byText[n.Text] then
                                            byText[n.Text] = {}
                                        end
                                        table.insert(byText[n.Text], n)
                                    end

                                    local texts = {}
                                    for txt, _ in pairs(byText) do
                                        table.insert(texts, txt)
                                    end

                                    local farmTargets = nil
                                    for _, txt in ipairs(texts) do
                                        if #byText[txt] >= 2 then
                                            farmTargets = byText[txt]
                                            break
                                        end
                                    end

                                    if farmTargets then
                                        for i = 1, #farmTargets do
                                            if not library.flags["nuke_farm"] then break end
                                            
                                            local target = farmTargets[i]
                                            
                                            if target.Obj and target.Obj.Parent then
                                                local overhead = target.Obj:FindFirstChild("OverheadNuke")
                                                local label = overhead and overhead:FindFirstChild("TextLabel")
                                                local currentText = label and label.Text
                                                
                                                if currentText == target.Text then
                                                    local freshPos = GetNukePos(target.Obj)
                                                    if freshPos then
                                                        TpTo(freshPos)
                                                    end
                                                else
                                                    break
                                                end
                                            else
                                                break
                                            end
                                            
                                            task.wait(0.5)
                                        end
                                    end
                                end
                            end
                        end
                    end
                    
                    task.wait(0.5)
                end
            end)
        end
    end
})

